# Reddit API credentials (for optional PRAW scraping)
# Create an app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CupidGPT/0.1 by your_username

# Hugging Face token with write access (for pushing the trained model)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Weights & Biases (training run tracking)
# https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=cupidgpt
